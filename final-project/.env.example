# ============================================
# Password Pusher — Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit the .env file to version control
# ============================================

# ── Docker Image ──
# Custom image built from official pwpush + branding overlay
DOCKER_IMAGE=pglombardo/pwpush:2.6.1

# ── PostgreSQL ──
POSTGRES_USER=pwpush
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=pwpush_production

# ── Password Pusher App ──
SECRET_KEY_BASE=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
APP_DOMAIN=pwpush.kulboka.com
GRAFANA_DOMAIN=grafana.kulboka.com
FORCE_SSL=true

# ── Branding ──
BRAND_TITLE=Secure Password Pusher
BRAND_TAGLINE=Share passwords securely

# ── Grafana ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
